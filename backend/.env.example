# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/subsq?sslmode=disable

# JWT
JWT_SECRET=your-secret-key-min-32-bytes-long

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Frontend
FRONTEND_URL=http://localhost:3000

# Server
API_PORT=8080
CLIENT_ORIGIN=http://localhost:3000

# Web Push (VAPID)
# 生成: npx web-push generate-vapid-keys
# 公開鍵は Frontend の NEXT_PUBLIC_VAPID_PUBLIC_KEY と一致させること
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
# Push サービスからの連絡先（mailto: or https URL）
VAPID_SUBJECT=mailto:your-email@example.com

# 管理用 API キー（GitHub Actions の broadcast から使用）
# 生成: openssl rand -hex 32
# 未設定時、admin エンドポイントは常に 401 を返す
ADMIN_API_KEY=your_admin_api_key
